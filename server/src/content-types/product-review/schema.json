{
  "kind": "collectionType",
  "collectionName": "product_reviews",
  "info": {
    "singularName": "product-review",
    "pluralName": "product-reviews",
    "displayName": "Product Review",
    "description": "Customer reviews for products"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "review": {
      "type": "text",
      "required": true
    },
    "rating": {
      "type": "integer",
      "required": true,
      "min": 1,
      "max": 5
    },
    "is_visible": {
      "type": "boolean",
      "default": false
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "product": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::webbycommerce.product",
      "inversedBy": "reviews"
    }
  }
}